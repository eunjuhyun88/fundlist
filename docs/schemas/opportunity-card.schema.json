{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fundlist.local/schemas/opportunity-card.schema.json",
  "title": "OpportunityCard",
  "type": "object",
  "required": [
    "opportunity_id",
    "organization_name",
    "program_name",
    "status",
    "checked_at",
    "deadline_date",
    "deadline_text",
    "days_left",
    "focus",
    "award_or_check_size",
    "what_they_want",
    "official_page",
    "apply_link",
    "confidence",
    "evidence"
  ],
  "properties": {
    "opportunity_id": {"type": "string"},
    "organization_name": {"type": "string"},
    "program_name": {"type": "string"},
    "opportunity_label": {"type": "string"},
    "status": {"type": "string", "enum": ["open", "rolling", "deadline", "closed", "unknown"]},
    "checked_at": {"type": "string", "format": "date-time"},
    "deadline_date": {"type": "string"},
    "deadline_text": {"type": "string"},
    "days_left": {"type": ["integer", "null"]},
    "focus": {"type": "array", "items": {"type": "string"}},
    "award_or_check_size": {"type": "string"},
    "what_they_want": {"type": "string"},
    "why_this_matters": {"type": "string"},
    "recommended_ask": {"type": "string"},
    "requirements": {"type": "string"},
    "official_page": {"type": "string"},
    "apply_link": {"type": "string"},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "evidence": {"type": "array", "items": {"type": "object"}}
  },
  "additionalProperties": false
}
